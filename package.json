{
  "name": "quicvarint",
  "version": "0.1.7",
  "description": "Variable-Length Integer Encoding defined by RFC 9000",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "vitest bench",
    "build": "tsdown --format esm,cjs --sourcemap --target es2022",
    "format": "prettier --write \"{src,test}/**/*.ts\" && oxlint --fix src test",
    "lint": "prettier --check \"{src,test}/**/*.ts\" && oxlint src test",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "watch": "npm run build -- --watch"
  },
  "repository": "github:thibmeu/quicvarint",
  "keywords": [
    "varint",
    "rfc9000",
    "cryptography",
    "2msb",
    "typescript"
  ],
  "author": "Thibault Meunier",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/thibmeu/quicvarint/issues"
  },
  "homepage": "https://github.com/thibmeu/quicvarint#readme",
  "overrides": {
    "tsdown": {
      "typescript": "$typescript"
    }
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.0",
    "fast-check": "^4.6.0",
    "oxlint": "^1.73.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.22.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.0"
  }
}
