{
  "name": "quicvarint",
  "version": "0.1.7",
  "description": "Variable-Length Integer Encoding defined by RFC 9000",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "vitest bench",
    "build": "tsdown --format esm,cjs --sourcemap --target es2022",
    "format": "eslint src/*.ts test/*.ts eslint.config.mjs --fix",
    "lint": "eslint src/*.ts test/*.ts eslint.config.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "watch": "npm run build -- --watch"
  },
  "repository": "github:thibmeu/quicvarint",
  "keywords": [
    "varint",
    "rfc9000",
    "cryptography",
    "2msb",
    "typescript"
  ],
  "author": "Thibault Meunier",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/thibmeu/quicvarint/issues"
  },
  "homepage": "https://github.com/thibmeu/quicvarint#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fast-check/vitest": "^0.4.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "fast-check": "^4.6.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
