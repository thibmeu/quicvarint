{
  "name": "bijou64",
  "version": "0.1.0",
  "description": "Variable-Length Integer Encoding based on bijou64",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "bench": "vitest bench",
    "build": "patch-package && tsup src/index.ts --format cjs,esm --dts --clean",
    "format": "eslint src/*.ts test/*.ts eslint.config.mjs --fix",
    "lint": "eslint src/*.ts test/*.ts eslint.config.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "watch": "npm run build -- --watch src"
  },
  "repository": "github:thibmeu/bijou64",
  "keywords": [
    "varint",
    "bijou64",
    "canonical",
    "typescript"
  ],
  "author": "Thibault Meunier",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/thibmeu/bijou64/issues"
  },
  "homepage": "https://github.com/thibmeu/bijou64#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fast-check/vitest": "^0.4.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "fast-check": "^4.6.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
