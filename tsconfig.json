{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["es2025"],
        "module": "preserve",
        "moduleResolution": "bundler",
        "strict": true,
        "declaration": true,
        "resolveJsonModule": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true
    },
    "include": ["src", "test"]
}
